#!/bin/sh

MSG_FILE="$1"
FIRST_LINE="$(sed -n '1p' "$MSG_FILE")"

if [ -z "$FIRST_LINE" ]; then
  echo "提交失败：commit message 不能为空。"
  exit 1
fi

node -e "const subject = process.argv[1] ?? ''; const prefix = /^(feat|fix|docs|chore|refactor|test|build|ci|perf|style|revert)(\([^)]+\))?: /; if (!prefix.test(subject)) process.exit(2); if (!/[\p{Script=Han}]/u.test(subject)) process.exit(3);" "$FIRST_LINE"
STATUS=$?

if [ $STATUS -eq 2 ]; then
  echo "提交失败：commit message 需使用约定前缀。"
  echo "示例：feat(editor-shell): 搭建 Tauri 桌面宿主骨架"
  echo "示例：docs(readme): 调整 README 对外说明结构"
  exit 1
fi

if [ $STATUS -eq 3 ]; then
  echo "提交失败：commit message 需包含中文描述。"
  echo "示例：feat(editor-shell): 搭建 Tauri 桌面宿主骨架"
  echo "示例：docs(readme): 调整 README 对外说明结构"
  exit 1
fi

exit 0
