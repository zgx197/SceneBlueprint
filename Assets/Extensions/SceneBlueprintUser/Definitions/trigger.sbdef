// 游戏特定 Trigger 类 Action 定义
// 由 SbdefCodegen 生成到 Generated/UAT.Trigger.g.cs / UActionPortIds.Trigger.g.cs / ActionDefs.Trigger.g.cs

action Trigger.EnterArea {
    displayName "进入区域"
    category    "Trigger"
    description "等待玩家进入指定区域后继续"
    themeColor  0.9 0.6 0.2
    duration    duration

    port string TriggerArea          label "触发区域"
    port bool   RequireFullyInside = false  label "需要完全进入"
}
