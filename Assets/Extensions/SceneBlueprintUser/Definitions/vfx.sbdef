// 游戏特定 VFX 类 Action 定义
// 由 SbdefCodegen 自动生成 Core/Generated/AT.Vfx.g.cs

action VFX.CameraShake {
    port float Duration  = 0.5
    port float Intensity = 1.0
    port float Frequency = 20.0
}

action VFX.ScreenFlash {
    port float  Duration  = 0.3
    port float  Intensity = 1.0
    port string FlashColor
}

action VFX.ShowWarning {
    port string Text
    port float  Duration = 3.0
    port string Style    = "default"
    port int    FontSize = 24
}
