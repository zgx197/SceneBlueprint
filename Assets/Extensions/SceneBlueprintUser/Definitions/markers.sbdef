// 游戏特定 Marker 类型定义
// 由 SbdefCodegen 生成到 Generated/UMarkerTypeIds.g.cs / UMarkers.g.cs / Editor/UMarkerDefs.g.cs

marker SpawnPoint {
    label "刷怪点"
    gizmo sphere(0.4)
}

marker TriggerZone {
    label "触发区域"
    gizmo wire_box
}

marker CameraTarget {
    label "摄像机目标"
    gizmo sphere(0.2)
}
